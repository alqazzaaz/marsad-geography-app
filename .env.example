# Copy to .env and fill in real values. Never commit the .env file.

# --- PostgreSQL ---
POSTGRES_USER=marsad
POSTGRES_PASSWORD=change-me
POSTGRES_DB=marsad

# --- Anthropic Claude API (required from Phase 4 — AI insights) ---
ANTHROPIC_API_KEY=

# --- Mapbox (required from Phase 3 — interactive map) ---
# IMPORTANT: restrict this token by URL in your Mapbox account settings
# (Account -> Tokens -> URL restrictions) so it only works on your domains.
MAPBOX_ACCESS_TOKEN=
