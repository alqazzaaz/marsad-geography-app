# Copy to .env and fill in real values. Never commit the .env file.

# --- PostgreSQL ---
POSTGRES_USER=marsad
POSTGRES_PASSWORD=change-me
POSTGRES_DB=marsad

# --- Anthropic Claude API (required from Phase 4 — AI insights) ---
ANTHROPIC_API_KEY=

# --- Sentry error tracking (optional; Phase 8 — observability) ---
# Create a project at sentry.io and paste its DSN. Empty = disabled.
SENTRY_DSN=
ENVIRONMENT=development

# --- JWT signing key (required from Phase 6 — auth) ---
# Generate a long random value, e.g.:  openssl rand -hex 48
JWT_SECRET_KEY=change-me-to-a-long-random-value

# --- Map worldview (optional) ---
# Comma-separated ISO codes; list BOTH alpha-2 and alpha-3 forms.
# Excluded countries are removed from map interactivity and labels;
# promoted countries become clickable (even where the base cartography
# marks their territory as disputed) and get a custom label.
MAP_EXCLUDED_COUNTRIES=
MAP_PROMOTED_COUNTRIES=

# --- Mapbox (required from Phase 3 — interactive map) ---
# IMPORTANT: restrict this token by URL in your Mapbox account settings
# (Account -> Tokens -> URL restrictions) so it only works on your domains.
MAPBOX_ACCESS_TOKEN=
